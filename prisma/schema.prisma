generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")  // Supabase auth.users.id
  role        UserRole
  fullName    String    @map("full_name")
  avatar      String?
  phone       String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  student     Student?
  counselor   Counselor?
  staff       Staff?

  @@map("profiles")
}

enum UserRole {
  admin
  counselor
  staff
  student
}

model Student {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  counselorId         String?   @map("counselor_id")

  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  dateOfBirth         DateTime? @map("date_of_birth") @db.Date
  gender              String?
  nationality         String    @default("Nepali")
  city                String?
  district            String?
  address             String?

  email               String    @unique
  phone               String?
  emergencyContact    String?   @map("emergency_contact")

  educationLevel      String?   @map("education_level")
  institutionName     String?   @map("institution_name")
  graduationYear      Int?      @map("graduation_year")
  gpaOrPercentage     String?   @map("gpa_or_percentage")
  stream              String?

  englishTest         String?   @map("english_test")
  englishScore        String?   @map("english_score")
  englishTestDate     DateTime? @map("english_test_date") @db.Date

  preferredCountries  String[]  @map("preferred_countries")
  preferredLevel      String?   @map("preferred_level")
  preferredField      String?   @map("preferred_field")
  targetIntake        String?   @map("target_intake")
  budgetRange         String?   @map("budget_range")

  profileStatus       ProfileStatus @default(INCOMPLETE) @map("profile_status")
  stage               ApplicationStageEnum @default(INQUIRY)
  source              String?

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  profile             Profile   @relation(fields: [userId], references: [userId])
  counselor           Counselor? @relation(fields: [counselorId], references: [userId])
  applications        Application[]
  documents           Document[]
  notes               CounselorNote[]
  fees                Fee[]
  notifications       Notification[]

  @@index([counselorId])
  @@index([stage])
  @@index([email])
  @@map("students")
}

enum ProfileStatus {
  INCOMPLETE
  COMPLETE
}

enum ApplicationStageEnum {
  INQUIRY
  PROFILE_COMPLETE
  UNIVERSITY_SELECTION
  DOCUMENTS_SUBMITTED
  APPLICATION_PREPARED
  APPLICATION_SUBMITTED
  OFFER_RECEIVED
  VISA_APPLIED
  VISA_APPROVED
  ENROLLED
  DEFERRED
  WITHDRAWN
}

model Counselor {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  specialization  String[]
  bio             String?
  maxStudents     Int       @default(30) @map("max_students")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  profile         Profile   @relation(fields: [userId], references: [userId])
  students        Student[]
  notes           CounselorNote[]
  tasks           Task[]

  @@map("counselors")
}

model Staff {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  department  String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  profile     Profile   @relation(fields: [userId], references: [userId])
  tasks       Task[]

  @@map("staff")
}

model University {
  id              String    @id @default(uuid())
  name            String
  country         String
  city            String?
  logoUrl         String?   @map("logo_url")
  websiteUrl      String?   @map("website_url")
  ranking         Int?
  type            String?
  description     String?
  isActive        Boolean   @default(true) @map("is_active")

  intakes         String[]
  applicationFee  Float?    @map("application_fee")

  minIelts        Float?    @map("min_ielts")
  minToefl        Int?      @map("min_toefl")
  minGpa          Float?    @map("min_gpa")
  tuitionRangeMin Float?    @map("tuition_range_min")
  tuitionRangeMax Float?    @map("tuition_range_max")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  programs        UniversityProgram[]
  applications    Application[]

  @@index([country])
  @@index([isActive])
  @@map("universities")
}

model UniversityProgram {
  id                String    @id @default(uuid())
  universityId      String    @map("university_id")
  name              String
  level             String
  field             String
  duration          String?
  tuitionFee        Float?    @map("tuition_fee")
  requirements      Json?
  deadline          DateTime? @db.Date
  isActive          Boolean   @default(true) @map("is_active")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  university        University @relation(fields: [universityId], references: [id])
  applications      Application[]

  @@index([universityId])
  @@index([level, field])
  @@map("university_programs")
}

model Application {
  id              String            @id @default(uuid())
  studentId       String            @map("student_id")
  universityId    String            @map("university_id")
  programId       String?           @map("program_id")
  counselorId     String            @map("counselor_id")

  intake          String
  status          ApplicationStatus @default(PREPARING)
  priority        Int               @default(1)

  submittedAt     DateTime?         @map("submitted_at")
  offerReceivedAt DateTime?         @map("offer_received_at")
  deadlineDate    DateTime?         @map("deadline_date") @db.Date

  offerType       String?           @map("offer_type")
  offerConditions String?           @map("offer_conditions")
  scholarshipAmount Float?          @map("scholarship_amount")

  visaAppliedAt   DateTime?         @map("visa_applied_at")
  visaDecision    String?           @map("visa_decision")
  visaDecisionAt  DateTime?         @map("visa_decision_at")

  notes           String?

  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  student         Student           @relation(fields: [studentId], references: [id])
  university      University        @relation(fields: [universityId], references: [id])
  program         UniversityProgram? @relation(fields: [programId], references: [id])
  statusHistory   ApplicationStatusHistory[]

  @@index([studentId])
  @@index([counselorId])
  @@index([status])
  @@map("applications")
}

enum ApplicationStatus {
  PREPARING
  SUBMITTED
  UNDER_REVIEW
  CONDITIONAL_OFFER
  UNCONDITIONAL_OFFER
  REJECTED
  WAITLISTED
  VISA_PREPARING
  VISA_SUBMITTED
  VISA_APPROVED
  VISA_REJECTED
  ENROLLED
  DEFERRED
  WITHDRAWN
}

model ApplicationStatusHistory {
  id              String            @id @default(uuid())
  applicationId   String            @map("application_id")
  changedById     String            @map("changed_by_id")
  fromStatus      ApplicationStatus? @map("from_status")
  toStatus        ApplicationStatus @map("to_status")
  note            String?
  changedAt       DateTime          @default(now()) @map("changed_at")

  application     Application       @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@map("application_status_history")
}

model Document {
  id              String         @id @default(uuid())
  studentId       String         @map("student_id")
  uploadedById    String         @map("uploaded_by_id")

  type            DocumentType
  name            String
  fileName        String         @map("file_name")
  storagePath     String         @map("storage_path")
  fileSizeBytes   Int?           @map("file_size_bytes")
  mimeType        String?        @map("mime_type")

  status          DocumentStatus @default(PENDING)
  reviewedById    String?        @map("reviewed_by_id")
  reviewedAt      DateTime?      @map("reviewed_at")
  reviewNote      String?        @map("review_note")

  expiryDate      DateTime?      @map("expiry_date") @db.Date

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  student         Student        @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([type])
  @@index([status])
  @@map("documents")
}

enum DocumentType {
  PASSPORT
  CITIZENSHIP
  ACADEMIC_TRANSCRIPT
  MARKSHEET
  CHARACTER_CERTIFICATE
  IELTS_RESULT
  TOEFL_RESULT
  PTE_RESULT
  DUOLINGO_RESULT
  SOP
  LOR
  CV_RESUME
  BANK_STATEMENT
  SPONSORSHIP_LETTER
  BIRTH_CERTIFICATE
  POLICE_CLEARANCE
  MEDICAL_REPORT
  VISA_COPY
  OFFER_LETTER
  ENROLLMENT_LETTER
  OTHER
}

enum DocumentStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

model CounselorNote {
  id          String    @id @default(uuid())
  studentId   String    @map("student_id")
  counselorId String    @map("counselor_id")
  content     String
  isPinned    Boolean   @default(false) @map("is_pinned")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  student     Student   @relation(fields: [studentId], references: [id])
  counselor   Counselor @relation(fields: [counselorId], references: [userId])

  @@index([studentId])
  @@index([counselorId])
  @@map("counselor_notes")
}

model Fee {
  id              String     @id @default(uuid())
  studentId       String     @map("student_id")
  createdById     String     @map("created_by_id")

  description     String
  amountNpr       Float?     @map("amount_npr")
  amountUsd       Float?     @map("amount_usd")
  currency        String     @default("NPR")
  status          FeeStatus  @default(PENDING)
  paidAt          DateTime?  @map("paid_at")
  invoiceNumber   String     @unique @map("invoice_number")
  receiptUrl      String?    @map("receipt_url")
  notes           String?

  dueDate         DateTime?  @map("due_date") @db.Date

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  student         Student    @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@map("fees")
}

enum FeeStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
  REFUNDED
}

model Task {
  id              String      @id @default(uuid())
  assignedToId    String      @map("assigned_to_id")
  studentId       String?     @map("student_id")
  createdById     String      @map("created_by_id")

  title           String
  description     String?
  status          TaskStatus  @default(PENDING)
  priority        TaskPriority @default(MEDIUM)
  dueDate         DateTime?   @map("due_date") @db.Date
  completedAt     DateTime?   @map("completed_at")

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  counselor       Counselor?  @relation(fields: [assignedToId], references: [userId], map: "tasks_counselor_fkey")
  staff           Staff?      @relation(fields: [assignedToId], references: [userId], map: "tasks_staff_fkey")

  @@index([assignedToId])
  @@index([studentId])
  @@index([status])
  @@map("tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  studentId   String?          @map("student_id")
  type        NotificationType
  title       String
  message     String
  link        String?
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")

  emailSent   Boolean          @default(false) @map("email_sent")
  emailSentAt DateTime?        @map("email_sent_at")

  createdAt   DateTime         @default(now()) @map("created_at")

  student     Student?         @relation(fields: [studentId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  APPLICATION_STATUS_CHANGED
  DOCUMENT_UPLOADED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  COUNSELOR_ASSIGNED
  DOCUMENT_REQUESTED
  DEADLINE_REMINDER
  PAYMENT_RECEIVED
  GENERAL
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  userRole    String   @map("user_role")
  action      String
  resource    String
  resourceId  String   @map("resource_id")
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
